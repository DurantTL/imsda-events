{
  "name": "imsda-events",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:public-capacity": "tsx scripts/verify-public-registration-capacity.ts",
    "test:public-access": "tsx scripts/verify-public-registration-access.ts",
    "test:public-messaging": "tsx scripts/verify-public-registration-messaging.ts",
    "test:public-roster": "tsx scripts/verify-public-registration-roster.ts",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:refresh-demo": "tsx scripts/refresh-local-demo.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.0"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.3.0",
    "@prisma/client": "^6.19.3",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "svix": "^1.99.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
