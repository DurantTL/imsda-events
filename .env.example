DATABASE_URL=postgresql://imsda:imsda_dev@localhost:5432/imsda_events?schema=public
APP_BASE_URL=http://localhost:3000
# Required in production to derive retry-stable private links without storing
# their raw bearer tokens. Use a random value of at least 32 characters.
MANAGE_LINK_DERIVATION_SECRET=
# During rotation, retain the prior value through the email retry window.
MANAGE_LINK_DERIVATION_SECRET_PREVIOUS=

# Signs stateless, PII-free attendee QR passes. Production requires a random
# value of at least 32 characters. Passes expire 48 hours after the event ends.
ATTENDEE_PASS_SIGNING_SECRET=
# During rotation, keep the prior value until every pass it signed has expired.
ATTENDEE_PASS_SIGNING_SECRET_PREVIOUS=

# Keyed, one-way request identifiers for durable abuse protection.
# Production requires a unique random value of at least 32 characters.
RATE_LIMIT_HASH_SECRET=
# Keep 0 unless the app is reachable only through exactly this many trusted
# proxies. X-Forwarded-For is ignored when this is 0.
RATE_LIMIT_TRUSTED_PROXY_HOPS=0
RATE_LIMIT_CLIENT_IP_HEADER=x-forwarded-for

# Public forms may be framed only by these origins. Keep imsda.org in production.
EMBED_ALLOWED_ORIGINS='self' https://imsda.org https://www.imsda.org

# Optional external confirmation delivery. Leave blank to keep local capture only.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com
RESEND_WEBHOOK_SECRET=

# Square checkout stays in Sandbox unless production is explicitly approved.
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_API_URL=https://connect.squareupsandbox.com
SQUARE_API_VERSION=2026-07-15
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Must exactly match the notification URL configured in Square.
SQUARE_WEBHOOK_NOTIFICATION_URL=http://localhost:3000/api/webhooks/square
SQUARE_ENABLE_PRODUCTION=false
